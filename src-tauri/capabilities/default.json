{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and popped-out terminal windows",
  "windows": [
    "main",
    "term-*"
  ],
  "permissions": [
    "core:default",
    "opener:default",
    "dialog:default",
    "core:webview:allow-create-webview-window",
    "core:window:allow-close",
    "core:window:allow-destroy"
  ]
}
