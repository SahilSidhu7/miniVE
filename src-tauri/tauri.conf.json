{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "miniVE",
  "mainBinaryName": "minive-app",
  "version": "0.3.0",
  "identifier": "com.sahil.minive",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "miniVE",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE3MUU3RjkyOTdGREQ3MDEKUldRQjEvMlhrbjhlRjg5Q0wwMHdlQjhrdllrYjlWZTNTMVBMY1l5TFlidkpGRVl3YjE3SFFEY1oK",
      "endpoints": [
        "https://github.com/SahilSidhu7/miniVE/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
